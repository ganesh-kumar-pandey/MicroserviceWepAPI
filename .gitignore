## C# Microservice .gitignore

# ----------------------------------------------------------------------
# Build and Publish Artifacts
# ----------------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
[Pp]ublish/
*.publishxml
*.pubxml
*.pubxml.user

# ----------------------------------------------------------------------
# Visual Studio & IDEs
# ----------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.user
*.userosscache
*.sln.docstates
*.suo
*.vssscc
*.tmp
*.bak
*.swp
*.DotSettings.user
*.resharper.user

# ----------------------------------------------------------------------
# Local Configuration & Secrets
# ----------------------------------------------------------------------
# Ignore local development environment configurations and secrets
appsettings.Development.json
appsettings.Local.json
.env
.env.local
.secret.json
secrets.json

# ----------------------------------------------------------------------
# Logs and Databases
# ----------------------------------------------------------------------
# Ignore log files generated by Serilog, NLog, etc.
*.log
[Ll]ogs/

# Ignore local database files (SQLite, LocalDB)
*.mdf
*.ldf
*.ndf
*.sqlite
*.db

# ----------------------------------------------------------------------
# OS Generated Files
# ----------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ----------------------------------------------------------------------
# Testing & Coverage
# ----------------------------------------------------------------------
[Tt]est[Rr]esults/
*.coverage
*.coveragexml
TestResult.xml
coveragereport/

# ----------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------
.dockerignore
docker-compose.override.yml
.devcontainer/

# ----------------------------------------------------------------------
# NuGet Packages
# ----------------------------------------------------------------------
*.nupkg
*.snupkg
[Pp]ackages/